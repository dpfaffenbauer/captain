{
  "expo": {
    "name": "Captain",
    "slug": "captain",
    "version": "1.0.0",
    "scheme": "captain",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "at.pfaffenbauer.captain",
      "entitlements": {
        "com.apple.security.application-groups": ["group.at.pfaffenbauer.captain"]
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Captain schützt gespeicherte Cluster-Zugangsdaten mit Face ID."
      },
      "appleTeamId": "UJ65F5V824"
    },
    "android": {
      "package": "at.pfaffenbauer.captain",
      "adaptiveIcon": {
        "backgroundColor": "#5D7BFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-local-authentication",
      "expo-background-task",
      "expo-notifications",
      "@bacons/apple-targets",
      [
        "expo-camera",
        {
          "cameraPermission": "Captain nutzt die Kamera, um Kubeconfig-QR-Codes zu scannen."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1bafa8e-5344-4204-be5f-91a6ca4b98de"
      }
    },
    "owner": "dpfaffenbauer"
  }
}
